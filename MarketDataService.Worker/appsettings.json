{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "MassTransit": "Information",
        "System.Net.Http": "Warning"
      }
    }
  },
  "Redis": {
    "ConnectionString": "redis:6379"
  },
  "RabbitMQ": {
    "Host": "rabbitmq",
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "Publishing": {
    "ClientThrottleMs": 200
  },
  "Health": {
    "StaleThresholdSeconds": 5
  },
  "Exchanges": {
    "Binance": {
      "ReconnectPolicy": {
        "MaxAttempts": 5,
        "InitialDelaySeconds": 1,
        "MaxDelaySeconds": 30
      }
    },
    "Aster": {
      "ReconnectPolicy": {
        "MaxAttempts": 5,
        "InitialDelaySeconds": 1,
        "MaxDelaySeconds": 30
      }
    }
  }
}
